{
  "openapi": "3.0.0",
  "info": {
    "title": "Cyfor Workshop API",
    "version": "1.0.0",
    "description": "Workshop starter API built with Hono, Prisma, and SQLite."
  },
  "components": {
    "schemas": {
      "RootResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "openapi": {
            "type": "string"
          }
        },
        "required": [
          "message",
          "openapi"
        ]
      },
      "HealthResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "ok"
            ]
          }
        },
        "required": [
          "status"
        ]
      },
      "Resource": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120,
            "example": "Conference room A"
          },
          "description": {
            "type": "string",
            "nullable": true,
            "example": "Main building, 2nd floor"
          },
          "category": {
            "type": "string",
            "minLength": 1,
            "maxLength": 60,
            "example": "Room"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "example": "2024-01-01T00:00:00.000Z"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "example": "2024-01-01T00:00:00.000Z"
          }
        },
        "required": [
          "id",
          "title",
          "description",
          "category",
          "createdAt",
          "updatedAt"
        ]
      },
      "ResourceListResponse": {
        "type": "object",
        "properties": {
          "resources": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Resource"
            }
          }
        },
        "required": [
          "resources"
        ]
      },
      "CreateResource": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120,
            "example": "Conference room A"
          },
          "description": {
            "type": "string",
            "maxLength": 500,
            "example": "Main building, 2nd floor"
          },
          "category": {
            "type": "string",
            "minLength": 1,
            "maxLength": 60,
            "example": "Room"
          }
        },
        "required": [
          "title",
          "category"
        ]
      },
      "UpdateResource": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120,
            "example": "Conference room B"
          },
          "description": {
            "type": "string",
            "nullable": true,
            "maxLength": 500,
            "example": "Updated description"
          },
          "category": {
            "type": "string",
            "minLength": 1,
            "maxLength": 60,
            "example": "Equipment"
          }
        }
      },
      "Reservation": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "resourceId": {
            "type": "integer",
            "example": 1
          },
          "reservedBy": {
            "type": "string",
            "example": "Ola Nordmann"
          },
          "date": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
            "example": "2026-04-24"
          },
          "startTime": {
            "type": "string",
            "pattern": "^\\d{2}:\\d{2}$",
            "example": "09:00"
          },
          "endTime": {
            "type": "string",
            "pattern": "^\\d{2}:\\d{2}$",
            "example": "11:00"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "example": "2024-01-01T00:00:00.000Z"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "example": "2024-01-01T00:00:00.000Z"
          }
        },
        "required": [
          "id",
          "resourceId",
          "reservedBy",
          "date",
          "startTime",
          "endTime",
          "createdAt",
          "updatedAt"
        ]
      },
      "ReservationListResponse": {
        "type": "object",
        "properties": {
          "reservations": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Reservation"
            }
          }
        },
        "required": [
          "reservations"
        ]
      },
      "CreateReservation": {
        "type": "object",
        "properties": {
          "reservedBy": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120,
            "example": "Ola Nordmann"
          },
          "date": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
            "example": "2026-04-24"
          },
          "startTime": {
            "type": "string",
            "pattern": "^\\d{2}:\\d{2}$",
            "example": "09:00"
          },
          "endTime": {
            "type": "string",
            "pattern": "^\\d{2}:\\d{2}$",
            "example": "11:00"
          }
        },
        "required": [
          "reservedBy",
          "date",
          "startTime",
          "endTime"
        ]
      }
    },
    "parameters": {}
  },
  "paths": {
    "/": {
      "get": {
        "tags": [
          "System"
        ],
        "responses": {
          "200": {
            "description": "Basic API information",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RootResponse"
                }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "tags": [
          "System"
        ],
        "responses": {
          "200": {
            "description": "Health check",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/resources": {
      "get": {
        "tags": [
          "Resources"
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "example": "conference"
            },
            "required": false,
            "name": "search",
            "in": "query"
          }
        ],
        "responses": {
          "200": {
            "description": "List all resources",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResourceListResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Resources"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateResource"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Create a new resource",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Resource"
                }
              }
            }
          }
        }
      }
    },
    "/resources/{id}": {
      "put": {
        "tags": [
          "Resources"
        ],
        "parameters": [
          {
            "schema": {
              "type": "integer",
              "minimum": 0,
              "exclusiveMinimum": true,
              "example": 1
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateResource"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Update an existing resource",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Resource"
                }
              }
            }
          },
          "404": {
            "description": "Resource not found"
          }
        }
      },
      "delete": {
        "tags": [
          "Resources"
        ],
        "parameters": [
          {
            "schema": {
              "type": "integer",
              "minimum": 0,
              "exclusiveMinimum": true,
              "example": 1
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "responses": {
          "204": {
            "description": "Remove a resource"
          }
        }
      }
    },
    "/resources/{id}/reservations": {
      "get": {
        "tags": [
          "Reservations"
        ],
        "parameters": [
          {
            "schema": {
              "type": "integer",
              "minimum": 0,
              "exclusiveMinimum": true,
              "example": 1
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "List reservations for a resource",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReservationListResponse"
                }
              }
            }
          },
          "404": {
            "description": "Resource not found"
          }
        }
      },
      "post": {
        "tags": [
          "Reservations"
        ],
        "parameters": [
          {
            "schema": {
              "type": "integer",
              "minimum": 0,
              "exclusiveMinimum": true,
              "example": 1
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateReservation"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Create a reservation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Reservation"
                }
              }
            }
          },
          "400": {
            "description": "Validation error (e.g. startTime >= endTime)"
          },
          "404": {
            "description": "Resource not found"
          },
          "409": {
            "description": "Time slot conflicts with an existing reservation"
          }
        }
      }
    },
    "/resources/{id}/reservations/{reservationId}": {
      "delete": {
        "tags": [
          "Reservations"
        ],
        "parameters": [
          {
            "schema": {
              "type": "integer",
              "minimum": 0,
              "exclusiveMinimum": true,
              "example": 1
            },
            "required": true,
            "name": "id",
            "in": "path"
          },
          {
            "schema": {
              "type": "integer",
              "minimum": 0,
              "exclusiveMinimum": true,
              "example": 1
            },
            "required": true,
            "name": "reservationId",
            "in": "path"
          }
        ],
        "responses": {
          "204": {
            "description": "Delete a reservation"
          }
        }
      }
    }
  }
}
