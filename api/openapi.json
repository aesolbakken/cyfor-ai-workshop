{
  "openapi": "3.0.0",
  "info": {
    "title": "Cyfor Workshop API",
    "version": "1.0.0",
    "description": "Workshop starter API built with Hono, Prisma, and SQLite."
  },
  "components": {
    "schemas": {
      "RootResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "openapi": {
            "type": "string"
          }
        },
        "required": [
          "message",
          "openapi"
        ]
      },
      "HealthResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "ok"
            ]
          }
        },
        "required": [
          "status"
        ]
      },
      "Category": {
        "type": "string",
        "enum": [
          "general",
          "room",
          "equipment",
          "vehicle",
          "workspace"
        ],
        "example": "room"
      },
      "Resource": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120,
            "example": "Conference Room A"
          },
          "description": {
            "type": "string",
            "maxLength": 500,
            "example": "Large meeting room on floor 3"
          },
          "category": {
            "$ref": "#/components/schemas/Category"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "example": "2024-01-01T00:00:00.000Z"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "example": "2024-01-01T00:00:00.000Z"
          }
        },
        "required": [
          "id",
          "title",
          "description",
          "category",
          "createdAt",
          "updatedAt"
        ]
      },
      "ResourceListResponse": {
        "type": "object",
        "properties": {
          "resources": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Resource"
            }
          }
        },
        "required": [
          "resources"
        ]
      },
      "CreateResource": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120,
            "example": "Conference Room A"
          },
          "description": {
            "type": "string",
            "maxLength": 500,
            "example": "Large meeting room on floor 3"
          },
          "category": {
            "$ref": "#/components/schemas/Category"
          }
        },
        "required": [
          "title"
        ]
      },
      "UpdateResource": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120,
            "example": "Conference Room B"
          },
          "description": {
            "type": "string",
            "maxLength": 500,
            "example": "Updated description"
          },
          "category": {
            "allOf": [
              {
                "$ref": "#/components/schemas/Category"
              },
              {
                "example": "equipment"
              }
            ]
          }
        }
      },
      "Reservation": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "resourceId": {
            "type": "integer",
            "example": 1
          },
          "bookedBy": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120,
            "example": "Alice"
          },
          "startTime": {
            "type": "string",
            "format": "date-time",
            "example": "2025-06-01T09:00:00.000Z"
          },
          "endTime": {
            "type": "string",
            "format": "date-time",
            "example": "2025-06-01T10:00:00.000Z"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "example": "2024-01-01T00:00:00.000Z"
          }
        },
        "required": [
          "id",
          "resourceId",
          "bookedBy",
          "startTime",
          "endTime",
          "createdAt"
        ]
      },
      "ReservationListResponse": {
        "type": "object",
        "properties": {
          "reservations": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Reservation"
            }
          }
        },
        "required": [
          "reservations"
        ]
      },
      "CreateReservation": {
        "type": "object",
        "properties": {
          "bookedBy": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120,
            "example": "Alice"
          },
          "startTime": {
            "type": "string",
            "format": "date-time",
            "example": "2025-06-01T09:00:00.000Z"
          },
          "endTime": {
            "type": "string",
            "format": "date-time",
            "example": "2025-06-01T10:00:00.000Z"
          }
        },
        "required": [
          "bookedBy",
          "startTime",
          "endTime"
        ]
      }
    },
    "parameters": {}
  },
  "paths": {
    "/": {
      "get": {
        "tags": [
          "System"
        ],
        "responses": {
          "200": {
            "description": "Basic API information",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RootResponse"
                }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "tags": [
          "System"
        ],
        "responses": {
          "200": {
            "description": "Health check",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/resources": {
      "get": {
        "tags": [
          "Resources"
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "example": "conference"
            },
            "required": false,
            "name": "search",
            "in": "query"
          },
          {
            "schema": {
              "$ref": "#/components/schemas/Category"
            },
            "required": false,
            "name": "category",
            "in": "query"
          }
        ],
        "responses": {
          "200": {
            "description": "List all resources, optionally filtered by search text and/or category",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResourceListResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Resources"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateResource"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Create a new resource",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Resource"
                }
              }
            }
          }
        }
      }
    },
    "/resources/{id}": {
      "put": {
        "tags": [
          "Resources"
        ],
        "parameters": [
          {
            "schema": {
              "type": "integer",
              "minimum": 0,
              "exclusiveMinimum": true,
              "example": 1
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateResource"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Update an existing resource",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Resource"
                }
              }
            }
          },
          "404": {
            "description": "Resource not found"
          }
        }
      },
      "delete": {
        "tags": [
          "Resources"
        ],
        "parameters": [
          {
            "schema": {
              "type": "integer",
              "minimum": 0,
              "exclusiveMinimum": true,
              "example": 1
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "responses": {
          "204": {
            "description": "Remove a resource"
          }
        }
      }
    },
    "/resources/{id}/reservations": {
      "get": {
        "tags": [
          "Reservations"
        ],
        "parameters": [
          {
            "schema": {
              "type": "integer",
              "minimum": 0,
              "exclusiveMinimum": true,
              "example": 1
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "List all reservations for a resource",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReservationListResponse"
                }
              }
            }
          },
          "404": {
            "description": "Resource not found"
          }
        }
      },
      "post": {
        "tags": [
          "Reservations"
        ],
        "parameters": [
          {
            "schema": {
              "type": "integer",
              "minimum": 0,
              "exclusiveMinimum": true,
              "example": 1
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateReservation"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Reservation created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Reservation"
                }
              }
            }
          },
          "404": {
            "description": "Resource not found"
          },
          "409": {
            "description": "Overlapping reservation exists"
          },
          "422": {
            "description": "Validation error (duration too short or start time in the past)"
          }
        }
      }
    },
    "/reservations/{id}": {
      "delete": {
        "tags": [
          "Reservations"
        ],
        "parameters": [
          {
            "schema": {
              "type": "integer",
              "minimum": 0,
              "exclusiveMinimum": true,
              "example": 1
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "responses": {
          "204": {
            "description": "Reservation deleted"
          },
          "404": {
            "description": "Reservation not found"
          }
        }
      }
    }
  }
}
