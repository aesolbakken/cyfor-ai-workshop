generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:../data/workshop.db"
}

model Resource {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  category    String   @default("Other")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
